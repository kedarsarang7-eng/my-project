# Copy values into each app's .env or CI — one API Gateway for all Flutter clients.
# Backend implementation: Dukan_x/my-backend (deploy with Serverless).

DUKANX_API_URL=https://api.dukanx.com

# Lambda env (deploy): enable QR/PWA routes under /api/v1/restaurant/*
RESTO_V1_PUBLIC_ENABLED=true
RESTO_V1_ORDER_SECRET=

# PWA web build — match RESTO_V1_ORDER_SECRET:
# flutter build web --dart-define=DUKANX_API_URL=https://api.dukanx.com --dart-define=RESTO_V1_ORDER_KEY=
