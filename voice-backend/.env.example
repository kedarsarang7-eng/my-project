# Zero-Failure Billing System - Environment Configuration
# Copy this to .env and fill in actual values

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/dukan
DATABASE_POOL_SIZE=20
DATABASE_SSL=true

# Read replica for reporting (optional)
DATABASE_READ_URL=postgresql://user:password@read-replica:5432/dukan

# =============================================================================
# REDIS (Idempotency/Caching)
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=dukan:billing:

# =============================================================================
# API CONFIGURATION
# =============================================================================
NODE_ENV=production
PORT=3000
API_BASE_URL=https://api.dukan.app
ALLOWED_ORIGINS=https://app.dukan.app,https://admin.dukan.app

# =============================================================================
# AUTHENTICATION
# =============================================================================
# SECURITY: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Server will CRASH at startup if this is not set!
JWT_SECRET=
JWT_EXPIRES_IN=7d

# =============================================================================
# AWS CONFIGURATION
# =============================================================================
# Firebase Service Account (loaded via env, NOT committed to repo)
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccountKey.json

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 for invoice storage
S3_BUCKET=dukan-invoices-prod
S3_BUCKET_REGION=ap-south-1

# =============================================================================
# KILL SWITCH CONFIGURATION
# =============================================================================
# Load Balancer ARNs (fill with actual values)
LEGACY_TARGET_GROUP_ARN=arn:aws:elasticloadbalancing:ap-south-1:ACCOUNT:targetgroup/legacy-billing/xxx
NEW_TARGET_GROUP_ARN=arn:aws:elasticloadbalancing:ap-south-1:ACCOUNT:targetgroup/new-billing/xxx
LISTENER_RULE_ARN=arn:aws:elasticloadbalancing:ap-south-1:ACCOUNT:listener-rule/xxx

# Kubernetes
K8S_NAMESPACE=dukan-prod

# =============================================================================
# PAYMENT GATEWAY
# =============================================================================
PAYMENT_GATEWAY=razorpay

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Stripe (alternative)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# NOTIFICATIONS
# =============================================================================
SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/xxx/xxx
PAGERDUTY_SERVICE_KEY=

# =============================================================================
# MONITORING
# =============================================================================
SENTRY_DSN=
LOG_LEVEL=info

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_SHADOW_MODE=false
ENABLE_NEW_BILLING=true
TRAFFIC_PERCENTAGE=100
