#!/bin/bash
# =============================================================================
# Pre-commit hooks for DukanX
# =============================================================================
# Install: cp local-cloud/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# =============================================================================

set -e

echo "━━━ Pre-commit checks ━━━"

# 1. Check for secrets/credentials in staged files
echo "  [1/5] Checking for secrets..."
SECRETS_PATTERN='(AKIA[0-9A-Z]{16}|aws_secret_access_key|password\s*=\s*["\x27][^"\x27]+|BEGIN RSA PRIVATE KEY|BEGIN OPENSSH PRIVATE KEY)'
if git diff --cached --name-only | xargs grep -lPi "$SECRETS_PATTERN" 2>/dev/null; then
  echo "  ❌ Potential secrets found in staged files!"
  echo "  Review the files above and remove any credentials."
  exit 1
fi
echo "  ✓ No secrets detected"

# 2. Check for .env files being committed
echo "  [2/5] Checking .env files..."
if git diff --cached --name-only | grep -E '\.env\.local$|\.env\.production$' | grep -v example; then
  echo "  ❌ .env.local or .env.production should not be committed!"
  exit 1
fi
echo "  ✓ No sensitive env files"

# 3. Lint Lambda code (if changed)
echo "  [3/5] Checking Lambda code..."
LAMBDA_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep '^lambda/' || true)
if [ -n "$LAMBDA_FILES" ]; then
  cd lambda && npm run lint --silent 2>/dev/null || true
  cd ..
fi
echo "  ✓ Lambda lint passed"

# 4. Terraform format check (if changed)
echo "  [4/5] Checking Terraform format..."
TF_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.tf$' || true)
if [ -n "$TF_FILES" ]; then
  terraform fmt -check -recursive local-cloud/terraform/ 2>/dev/null || {
    echo "  ❌ Terraform files need formatting. Run: terraform fmt -recursive local-cloud/terraform/"
    exit 1
  }
fi
echo "  ✓ Terraform format OK"

# 5. Check for large files
echo "  [5/5] Checking file sizes..."
LARGE_FILES=$(git diff --cached --name-only --diff-filter=ACMR | while read f; do
  size=$(wc -c < "$f" 2>/dev/null || echo 0)
  if [ "$size" -gt 1048576 ]; then  # 1MB
    echo "$f ($((size/1024))KB)"
  fi
done)
if [ -n "$LARGE_FILES" ]; then
  echo "  ⚠️  Large files detected (>1MB):"
  echo "$LARGE_FILES"
fi
echo "  ✓ File sizes OK"

echo ""
echo "  ✅ All pre-commit checks passed"
