{
  "id": "dukanx",
  "realm": "dukanx",
  "enabled": true,
  "displayName": "DukanX Local Development",
  "sslRequired": "none",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "permanentLockout": false,
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "defaultSignatureAlgorithm": "RS256",
  "roles": {
    "realm": [
      { "name": "OWNER", "description": "Business owner with full access" },
      { "name": "MANAGER", "description": "Manager with limited admin access" },
      { "name": "STAFF", "description": "Staff member with operational access" },
      { "name": "VIEWER", "description": "Read-only access" },
      { "name": "SCHOOL_ADMIN", "description": "School administration access" },
      { "name": "SCHOOL_STAFF", "description": "School staff access" },
      { "name": "CUSTOMER", "description": "Customer app access" }
    ]
  },
  "groups": [
    { "name": "owners", "path": "/owners" },
    { "name": "managers", "path": "/managers" },
    { "name": "staff", "path": "/staff" },
    { "name": "admin", "path": "/admin" },
    { "name": "school_admin", "path": "/school_admin" },
    { "name": "school_staff", "path": "/school_staff" },
    { "name": "customers", "path": "/customers" }
  ],
