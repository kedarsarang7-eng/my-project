{
    "name": "dukanx-local-backend",
    "version": "1.0.0",
    "private": true,
    "description": "Packaged offline Local_Backend (Express + Socket.io) for DukanX Offline_Lifetime_Mode. Mirrors the AWS my-backend API contracts on the loopback interface (127.0.0.1:8765).",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "start": "node dist/server.js",
        "dev": "tsx watch src/server.ts",
        "test": "jest --runInBand"
    },
    "dependencies": {
        "bcryptjs": "2.4.3",
        "better-sqlite3": "12.10.0",
        "cors": "2.8.5",
        "express": "4.22.2",
        "jsonwebtoken": "9.0.3",
        "socket.io": "4.8.1"
    },
    "devDependencies": {
        "@types/bcryptjs": "2.4.6",
        "@types/better-sqlite3": "7.6.13",
        "@types/cors": "2.8.17",
        "@types/express": "4.17.21",
        "@types/jest": "29.5.12",
        "@types/jsonwebtoken": "9.0.10",
        "@types/node": "20.19.9",
        "@types/supertest": "6.0.2",
        "jest": "29.7.0",
        "socket.io-client": "4.8.1",
        "supertest": "6.3.4",
        "ts-jest": "29.1.2",
        "tsx": "4.20.6",
        "typescript": "5.3.3"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
