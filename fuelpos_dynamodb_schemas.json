  "tenantIsolation": {
    "description": "All data is isolated by tenantId. Each query must include tenantId validation against the user's license profile.",
    "pattern": "TENANT#{tenantId} is stored in every item and verified in Lambda authorizer",
    "accessControl": {
      "read": "User can only read data where item.tenantId == user.tenantId",
      "write": "User can only write data with item.tenantId == user.tenantId",
      "crossTenantAccess": "STRICTLY PROHIBITED - Returns 403 Forbidden"
    }
  }
}
