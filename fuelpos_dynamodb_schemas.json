{
  "description": "DynamoDB Table Schemas for FuelPOS - Petrol Pump Management System",
  "tables": {
    "FuelPOS_Transactions": {
      "TableName": "{StackName}-fuelpos-transactions",
      "AttributeDefinitions": [
        { "AttributeName": "PK", "AttributeType": "S" },
        { "AttributeName": "SK", "AttributeType": "S" },
        { "AttributeName": "GSI1PK", "AttributeType": "S" },
        { "AttributeName": "GSI1SK", "AttributeType": "S" },
        { "AttributeName": "GSI2PK", "AttributeType": "S" },
        { "AttributeName": "GSI2SK", "AttributeType": "S" }
      ],
      "KeySchema": [
        { "AttributeName": "PK", "KeyType": "HASH" },
        { "AttributeName": "SK", "KeyType": "RANGE" }
      ],
      "GlobalSecondaryIndexes": [
        {
          "IndexName": "GSI_DateRange",
          "KeySchema": [
            { "AttributeName": "GSI1PK", "KeyType": "HASH" },
            { "AttributeName": "GSI1SK", "KeyType": "RANGE" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        },
        {
          "IndexName": "GSI_Vehicle",
          "KeySchema": [
            { "AttributeName": "GSI2PK", "KeyType": "HASH" },
            { "AttributeName": "GSI2SK", "KeyType": "RANGE" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        }
      ],
      "BillingMode": "PAY_PER_REQUEST",
      "StreamSpecification": { "StreamViewType": "NEW_AND_OLD_IMAGES" },
      "PointInTimeRecoverySpecification": { "PointInTimeRecoveryEnabled": true }
    },
    "FuelPOS_Inventory": {
      "TableName": "{StackName}-fuelpos-inventory",
      "AttributeDefinitions": [
        { "AttributeName": "PK", "AttributeType": "S" },
        { "AttributeName": "SK", "AttributeType": "S" },
        { "AttributeName": "GSI1PK", "AttributeType": "S" }
      ],
      "KeySchema": [
        { "AttributeName": "PK", "KeyType": "HASH" },
        { "AttributeName": "SK", "KeyType": "RANGE" }
      ],
      "GlobalSecondaryIndexes": [
        {
          "IndexName": "GSI_AlertStatus",
          "KeySchema": [
            { "AttributeName": "GSI1PK", "KeyType": "HASH" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        }
      ],
      "BillingMode": "PAY_PER_REQUEST",
      "StreamSpecification": { "StreamViewType": "NEW_AND_OLD_IMAGES" },
      "PointInTimeRecoverySpecification": { "PointInTimeRecoveryEnabled": true }
    },
    "FuelPOS_DailySummary": {
      "TableName": "{StackName}-fuelpos-daily-summary",
      "AttributeDefinitions": [
        { "AttributeName": "PK", "AttributeType": "S" },
        { "AttributeName": "SK", "AttributeType": "S" },
        { "AttributeName": "GSI1PK", "AttributeType": "S" },
        { "AttributeName": "GSI1SK", "AttributeType": "S" }
      ],
      "KeySchema": [
        { "AttributeName": "PK", "KeyType": "HASH" },
        { "AttributeName": "SK", "KeyType": "RANGE" }
      ],
      "GlobalSecondaryIndexes": [
        {
          "IndexName": "GSI_MonthlyReport",
          "KeySchema": [
            { "AttributeName": "GSI1PK", "KeyType": "HASH" },
            { "AttributeName": "GSI1SK", "KeyType": "RANGE" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        }
      ],
      "BillingMode": "PAY_PER_REQUEST",
      "PointInTimeRecoverySpecification": { "PointInTimeRecoveryEnabled": true }
    },
    "FuelPOS_FuelChart": {
      "TableName": "{StackName}-fuelpos-fuel-chart",
      "AttributeDefinitions": [
        { "AttributeName": "PK", "AttributeType": "S" },
        { "AttributeName": "SK", "AttributeType": "S" }
      ],
      "KeySchema": [
        { "AttributeName": "PK", "KeyType": "HASH" },
        { "AttributeName": "SK", "KeyType": "RANGE" }
      ],
      "BillingMode": "PAY_PER_REQUEST",
      "PointInTimeRecoverySpecification": { "PointInTimeRecoveryEnabled": true }
    },
    "FuelPOS_Prices": {
      "TableName": "{StackName}-fuelpos-prices",
      "AttributeDefinitions": [
        { "AttributeName": "PK", "AttributeType": "S" },
        { "AttributeName": "SK", "AttributeType": "S" },
        { "AttributeName": "GSI1PK", "AttributeType": "S" }
      ],
      "KeySchema": [
        { "AttributeName": "PK", "KeyType": "HASH" },
        { "AttributeName": "SK", "KeyType": "RANGE" }
      ],
      "GlobalSecondaryIndexes": [
        {
          "IndexName": "GSI_EffectiveDate",
          "KeySchema": [
            { "AttributeName": "GSI1PK", "KeyType": "HASH" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        }
      ],
      "BillingMode": "PAY_PER_REQUEST"
    },
    "FuelPOS_Employees": {
      "TableName": "{StackName}-fuelpos-employees",
      "AttributeDefinitions": [
        { "AttributeName": "PK", "AttributeType": "S" },
        { "AttributeName": "SK", "AttributeType": "S" },
        { "AttributeName": "GSI1PK", "AttributeType": "S" }
      ],
      "KeySchema": [
        { "AttributeName": "PK", "KeyType": "HASH" },
        { "AttributeName": "SK", "KeyType": "RANGE" }
      ],
      "GlobalSecondaryIndexes": [
        {
          "IndexName": "GSI_OnDuty",
          "KeySchema": [
            { "AttributeName": "GSI1PK", "KeyType": "HASH" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        }
      ],
      "BillingMode": "PAY_PER_REQUEST"
    },
    "FuelPOS_LicenseProfiles": {
      "TableName": "{StackName}-fuelpos-license-profiles",
      "AttributeDefinitions": [
        { "AttributeName": "PK", "AttributeType": "S" },
        { "AttributeName": "SK", "AttributeType": "S" },
        { "AttributeName": "GSI1PK", "AttributeType": "S" }
      ],
      "KeySchema": [
        { "AttributeName": "PK", "KeyType": "HASH" },
        { "AttributeName": "SK", "KeyType": "RANGE" }
      ],
      "GlobalSecondaryIndexes": [
        {
          "IndexName": "GSI_LicenseKey",
          "KeySchema": [
            { "AttributeName": "GSI1PK", "KeyType": "HASH" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        }
      ],
      "BillingMode": "PAY_PER_REQUEST"
    }
  },
