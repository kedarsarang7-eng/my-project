{
    "name": "bizmate-serverless-backend",
    "version": "1.0.0",
    "description": "BizMate Multi-Tenant SaaS Backend — AWS Lambda + API Gateway",
    "main": "dist/handlers/dashboard.js",
    "scripts": {
        "build": "tsc",
        "deploy": "serverless deploy",
        "deploy:dev": "serverless deploy --stage dev",
        "deploy:prod": "serverless deploy --stage prod",
        "offline": "serverless offline",
        "offline:dev": "NODE_ENV=development serverless offline --stage dev",
        "offline:staging": "NODE_ENV=staging serverless offline --stage staging",
        "deploy:staging": "serverless deploy --stage staging",
        "lint": "eslint src/**/*.ts",
        "test": "jest --runInBand",
        "typecheck": "tsc --noEmit",
        "openapi:sync": "node scripts/sync-openapi.js",
        "openapi:check": "node scripts/check-openapi-drift.js",
        "serverless:check-handlers": "node scripts/check-serverless-handlers.js",
        "pharmacy:gsi:backfill:dry": "node scripts/backfill-pharmacy-gsi.js --dry-run",
        "pharmacy:gsi:backfill": "node scripts/backfill-pharmacy-gsi.js"
    },
    "dependencies": {
        "@aws-sdk/client-apigatewaymanagementapi": "^3.1003.0",
        "@aws-sdk/client-cloudwatch": "^3.998.0",
        "@aws-sdk/client-cognito-identity-provider": "^3.500.0",
        "@aws-sdk/client-dynamodb": "^3.1024.0",
        "@aws-sdk/client-eventbridge": "^3.1003.0",
        "@aws-sdk/client-kms": "^3.998.0",
        "@aws-sdk/client-rekognition": "^3.990.0",
        "@aws-sdk/client-s3": "^3.500.0",
        "@aws-sdk/client-secrets-manager": "^3.1002.0",
        "@aws-sdk/client-ses": "^3.998.0",
        "@aws-sdk/client-sns": "^3.998.0",
        "@aws-sdk/client-sqs": "^3.1024.0",
        "@aws-sdk/client-textract": "^3.1024.0",
        "@aws-sdk/lib-dynamodb": "^3.1024.0",
        "@aws-sdk/s3-request-presigner": "^3.500.0",
        "@opensearch-project/opensearch": "^2.5.0",
        "ajv": "^8.20.0",
        "ajv-formats": "^3.0.1",
        "aws-jwt-verify": "^4.0.1",
        "dayjs": "^1.11.10",
        "exceljs": "^4.4.0",
        "jsonwebtoken": "^9.0.3",
        "pdfkit": "^0.18.0",
        "uuid": "^9.0.0",
        "zod": "^4.3.6"
    },
    "optionalDependencies": {
        "ioredis": "^5.3.2"
    },
    "devDependencies": {
        "@types/aws-lambda": "^8.10.161",
        "@types/cors": "^2.8.17",
        "@types/dotenv": "^6.1.1",
        "@types/exceljs": "^0.5.2",
        "@types/express": "^4.17.21",
        "@types/ioredis": "^4.28.10",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^24.0.0",
        "@types/pdfkit": "^0.17.6",
        "@types/uuid": "^9.0.7",
        "dotenv": "^17.3.1",
        "jest": "^30.2.0",
        "serverless": "^4.31.2",
        "serverless-offline": "^14.4.0",
        "serverless-plugin-split-stacks": "^1.14.0",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
