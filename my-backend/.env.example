# ============================================================================
# DukanX Backend (my-backend) — Environment Variables Template
# ============================================================================
# Copy to .env and fill in values. NEVER commit .env with real secrets.
# ============================================================================

# ── AWS Core ────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1

# ── DynamoDB (Single Table Design) ──────────────────────────────────────────
DYNAMODB_TABLE=DukanX-dev
# RATE_LIMIT_TABLE=  # Optional — defaults to ${DYNAMODB_TABLE}-rate-limits

# ── Cognito ─────────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=ap-south-1
COGNITO_DESKTOP_CLIENT_ID=
COGNITO_MOBILE_CLIENT_ID=
COGNITO_ADMIN_CLIENT_ID=
COGNITO_IDENTITY_POOL_ID=

# ── S3 Storage ──────────────────────────────────────────────────────────────
S3_BUCKET_NAME=
S3_REGION=ap-south-1

# ── WebSocket ───────────────────────────────────────────────────────────────
WEBSOCKET_API_ENDPOINT=

# ── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
ENVIRONMENT=development
LOG_LEVEL=debug

# ── Internal M2M Secrets ────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=
MANIFEST_JWT_SECRET=

# ── AI Configuration ────────────────────────────────────────────────────────
DUKANX_AI_DEFAULT_PROVIDER=ollama
DUKANX_AI_API_KEY=
# ANTHROPIC_API_KEY=

# ── OpenSearch ──────────────────────────────────────────────────────────────
# OPENSEARCH_ENDPOINT=

# ── Payment / Razorpay ──────────────────────────────────────────────────────
# ⚠️  CRITICAL (P0-1/P0-2): These are REQUIRED for payment processing
# Get from Razorpay Dashboard → Settings → API Keys
# For production: Use LIVE keys (rzp_live_...), NEVER test keys (rzp_test_...)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Platform fee percentage for commission splitting (P1-10)
# Example: 2.5 means 2.5% platform fee on each transaction
PLATFORM_FEE_PERCENT=2.5

# ── Razorpay Subscription Plan IDs ──────────────────────────────────────────
# ⚠️  CRITICAL (P1-5): Create these in Razorpay Dashboard → Subscriptions → Plans
# NEVER use placeholder/dummy values in production - app will FAIL STARTUP
#
# Create 24 plans (4 tiers × 6 billing cycles):
# Basic: ₹249/mo | ₹2,499/yr | ₹4,499/2yr | ₹5,999/3yr + quarterly ₹699, biannual ₹1,299
# Pro: ₹499/mo | ₹4,999/yr | ₹8,999/2yr | ₹11,999/3yr + quarterly ₹1,399, biannual ₹2,599
# Premium: ₹999/mo | ₹9,999/yr | ₹17,999/2yr | ₹24,999/3yr + quarterly ₹2,799, biannual ₹5,299
# Enterprise: ₹1,999/mo | ₹19,999/yr | ₹35,999/2yr | ₹49,999/3yr + quarterly ₹5,499, biannual ₹10,499
#
RAZORPAY_PLAN_BASIC_MONTHLY=
RAZORPAY_PLAN_BASIC_QUARTERLY=
RAZORPAY_PLAN_BASIC_BIANNUAL=
RAZORPAY_PLAN_BASIC_YEARLY=
RAZORPAY_PLAN_BASIC_BIENNIAL=
RAZORPAY_PLAN_BASIC_TRIENNIAL=
RAZORPAY_PLAN_PRO_MONTHLY=
RAZORPAY_PLAN_PRO_QUARTERLY=
RAZORPAY_PLAN_PRO_BIANNUAL=
RAZORPAY_PLAN_PRO_YEARLY=
RAZORPAY_PLAN_PRO_BIENNIAL=
RAZORPAY_PLAN_PRO_TRIENNIAL=
RAZORPAY_PLAN_PREMIUM_MONTHLY=
RAZORPAY_PLAN_PREMIUM_QUARTERLY=
RAZORPAY_PLAN_PREMIUM_BIANNUAL=
RAZORPAY_PLAN_PREMIUM_YEARLY=
RAZORPAY_PLAN_PREMIUM_BIENNIAL=
RAZORPAY_PLAN_PREMIUM_TRIENNIAL=
RAZORPAY_PLAN_ENTERPRISE_MONTHLY=
RAZORPAY_PLAN_ENTERPRISE_QUARTERLY=
RAZORPAY_PLAN_ENTERPRISE_BIANNUAL=
RAZORPAY_PLAN_ENTERPRISE_YEARLY=
RAZORPAY_PLAN_ENTERPRISE_BIENNIAL=
RAZORPAY_PLAN_ENTERPRISE_TRIENNIAL=

# ── CORS Origins ────────────────────────────────────────────────────────────
# CORS_ORIGIN_1=https://app.dukanx.com
# CORS_ORIGIN_2=https://admin.dukanx.com

# ── Pump / ATG ──────────────────────────────────────────────────────────────
# PUMP_ATG_CONNECTOR_TOKEN=

# ── Search ──────────────────────────────────────────────────────────────────
# FUZZY_THRESHOLD=0.85

# ── DynamoDB Local (testing only) ───────────────────────────────────────────
# DYNAMODB_LOCAL=true
