{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": [
            "ES2022"
        ],
        "outDir": "./dist",
        "rootDir": "../src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": false,
        "sourceMap": false,
        "baseUrl": "..",
        "paths": {
            "../utils/*": [
                "src/utils/*"
            ],
            "../types/*": [
                "src/types/*"
            ],
            "../schemas/*": [
                "src/schemas/*"
            ],
            "../services/*": [
                "src/services/*"
            ]
        }
    },
    "include": [
        "../src/handlers/websocket.ts",
        "../src/services/websocket.service.ts",
        "../src/types/websocket.types.ts",
        "../src/schemas/websocket.schema.ts",
        "../src/utils/logger.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}