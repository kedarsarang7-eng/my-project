      '/license': (context) => const LicenseScreen(),

      // Dashboard Selection
      '/dashboard_selection': (context) => const LoginPage(),

      // Linking
      '/vendor_qr_code': (context) =>
          VendorRoleGuard(
            requiredPermission: Permissions.manageStaff,
            child: const VendorQRCodeScreen(),
          ),
      '/customer_link_shop': (context) => const CustomerLinkShopScreen(),

      // Core
      '/startup': (context) => const LicenseScreen(),
      '/home': (context) =>
          const ProtectedRoute(requiredPermission: Permissions.viewInvoices, child: DesktopRootShell()),
      '/home_modern': (context) =>
          const ProtectedRoute(requiredPermission: Permissions.viewInvoices, child: DesktopRootShell()),
      '/enhanced_dashboard': (context) => const OwnerDashboardRedirect(),
      // BUG-004 FIX: Specialized dashboards with proper routing
      '/specialized_dashboard/restaurant': (context) =>
          const SpecializedDashboardRedirect(businessType: 'restaurant'),
      '/specialized_dashboard/clinic': (context) => 
          const SpecializedDashboardRedirect(businessType: 'clinic'),
      '/owner_dashboard': (context) =>
          const ProtectedRoute(requiredPermission: Permissions.viewInvoices, child: DesktopRootShell()),

      // Pharmacy Dashboard (Business Type Specific)
      '/pharmacy/dashboard': (context) =>
          const ProtectedRoute(requiredPermission: Permissions.viewInvoices, child: PharmacyDashboardScreen()),

      // Legacy redirects
      '/signup': (context) => const LoginPage(),
      '/owner_login': (context) => const LoginPage(),
      '/customer_login': (context) => const LoginPage(),

      '/shop_selection': (context) => const ShopSelectionScreen(),
      // Legacy redirects → License screen (plan controlled by Super Admin)
      '/business_type_selection': (context) => const LicenseScreen(),

      // Vendor Onboarding removed — license defines business type
      // '/vendor_onboarding' route eliminated
      '/business_settings': (context) =>
          VendorRoleGuard(
            requiredPermission: Permissions.systemSettings,
            child: const BusinessSettingsScreen(),
          ),
      '/vendor_profile': (context) =>
          VendorRoleGuard(
            requiredPermission: Permissions.systemSettings,
            child: const VendorProfileScreen(),
          ),

      // Billing (Owner Protected)
      // '/billing': (context) => VendorRoleGuard(child: const BillingScreen()),
      '/pending': (context) => VendorRoleGuard(
            requiredPermission: Permissions.viewInvoices,
